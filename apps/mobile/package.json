{
  "name": "@opc/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "OPC React Native mobile client",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "bundle:android": "expo export:embed --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "bundle:ios": "expo export:embed --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/app/build ios/build ios/Pods node_modules",
    "eas-build-post-install": "cd ../.. && pnpm --filter '@opc/api-client' --filter '@opc/mqtt-client' build"
  },
  "dependencies": {
    "@opc/api-client": "workspace:*",
    "@opc/mqtt-client": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@tanstack/react-query": "^5.74.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "expo": "^57.0.6",
    "expo-build-properties": "^57.0.5",
    "expo-constants": "^57.0.5",
    "mqtt": "^5.10.1",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.26.1",
    "react-native-tcp-socket": "^6.2.0",
    "stream-browserify": "^3.0.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "babel-preset-expo": "~57.0.3",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eas-cli": "^21.0.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
