{
  "name": "@opc/mqtt-client",
  "version": "1.0.0",
  "private": true,
  "description": "MQTT client for OPC real-time messaging",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
